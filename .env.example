# Environment variables

# Database Configuration (MySQL - Hostinger)
# Format: mysql://USERNAME:PASSWORD@localhost:3306/DATABASE_NAME
DATABASE_URL="mysql://u123456_tashtep:yourpassword@localhost:3306/u123456_tashtep"

# Authentication (NextAuth)
NEXTAUTH_SECRET="your-super-strong-secret-key-for-next-auth"
NEXTAUTH_URL="http://localhost:3000"

# Paymob Integration
PAYMOB_API_KEY=""
PAYMOB_IFRAME_ID=""
PAYMOB_INTEGRATION_ID=""

# Email Service (Resend)
RESEND_API_KEY=""

# Application Configuration
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Sentry Monitoring
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# SEO: Google Analytics 4 (optional — leave empty to disable)
NEXT_PUBLIC_GA_ID=""

# SEO: Google Search Console ownership verification meta tag (optional)
# Get this from Search Console > Settings > Ownership verification > HTML tag
GOOGLE_SITE_VERIFICATION=""
